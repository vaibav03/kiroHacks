{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on saved TypeScript/TSX files to catch issues before they hit the browser",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx next lint --file {file}"
  }
}